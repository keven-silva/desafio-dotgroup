# Usado só pelo docker-compose.yml (Postgres) na raiz do repo.
# Cada serviço (apps/*) tem seu próprio .env.example com as variáveis que ele precisa —
# veja apps/library_api/.env.example, apps/rag/.env.example e apps/chatbot/.env.example.

POSTGRES_USER=dotgroup
POSTGRES_PASSWORD=dotgroup
POSTGRES_DB=library
POSTGRES_PORT=5432
