# --- postgres / docker-compose ---
POSTGRES_USER=dotgroup
POSTGRES_PASSWORD=dotgroup
POSTGRES_DB=library
POSTGRES_PORT=5432

# --- library_api ---
# usada pelo SQLAlchemy async (driver asyncpg)
DATABASE_URL=postgresql+asyncpg://dotgroup:dotgroup@localhost:5432/library

# --- rag (embeddings + vector store) ---
# sentence-transformers (local, gratuito) ou openai (pago, precisa de OPENAI_API_KEY)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_DATA_DIR=apps/rag/data/raw
RAG_INDEX_DIR=apps/rag/data/index

# --- chatbot ---
OPENAI_API_KEY=sk-changeme
CHATBOT_MODEL=gpt-4o-mini

# --- logging estruturado (libs/observability) ---
LOG_LEVEL=INFO
LOG_JSON=true
