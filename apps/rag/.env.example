# sentence-transformers (local, gratuito) ou openai (pago, precisa de OPENAI_API_KEY)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# só necessária se EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-changeme

# opcionais — por padrão apontam para data/raw e data/index dentro desta pasta (apps/rag)
# RAG_DATA_DIR=data/raw
# RAG_INDEX_DIR=data/index

# tamanho/sobreposição dos chunks gerados a partir dos documentos de origem
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# logging estruturado (libs/observability)
LOG_LEVEL=INFO
LOG_JSON=true
