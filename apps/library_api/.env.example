# usada pelo SQLAlchemy async (driver asyncpg) — precisa bater com o docker-compose da raiz
# (POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB/POSTGRES_PORT)
DATABASE_URL=postgresql+asyncpg://dotgroup:dotgroup@localhost:5432/library

# quantos dias dura um empréstimo por padrão
DEFAULT_LOAN_PERIOD_DAYS=14

# origens liberadas para CORS, separadas por vírgula (ou "*" para liberar geral)
CORS_ALLOWED_ORIGINS=*

# logging estruturado (libs/observability)
LOG_LEVEL=INFO
LOG_JSON=true
