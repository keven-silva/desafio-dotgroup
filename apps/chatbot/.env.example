# chave real da OpenAI — obrigatória para o chatbot responder de verdade
OPENAI_API_KEY=sk-changeme
CHATBOT_MODEL=gpt-4o-mini

# URL do serviço `rag` (best-effort: se indisponível, o chatbot responde sem contexto)
RAG_API_URL=http://localhost:8001
# quantos trechos recuperar do rag para compor o contexto de cada pergunta
RAG_CONTEXT_K=3

# logging estruturado (libs/observability)
LOG_LEVEL=INFO
LOG_JSON=true
